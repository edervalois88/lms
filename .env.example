APP_NAME=NexusEdu
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_MX

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nexusedu
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=nexusedu

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@nexusedu.test"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

VECTOR_PROVIDER=qdrant
VECTOR_URL=
VECTOR_API_KEY=
VECTOR_COLLECTION=exam_context

# Startup automation controls (Docker/Railway)
AUTO_RUN_MIGRATIONS=true
AUTO_RUN_SEEDERS=false
AUTO_OPTIMIZE_CLEAR=true
AUTO_CONFIG_CACHE=true

# Auto-managed queue worker (same container)
ENABLE_QUEUE_WORKER=false
QUEUE_WORKER_SLEEP=1
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=120

TELESCOPE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
